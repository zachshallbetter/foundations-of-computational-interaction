{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prediction-record.schema.json",
  "title": "CompInt Prediction Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prediction_id",
    "prediction_contract_ref",
    "target",
    "unit",
    "horizon",
    "information_cutoff",
    "population",
    "context",
    "model_version",
    "prediction",
    "uncertainty_ref",
    "calibration_status",
    "transport_scope",
    "failure_conditions",
    "provenance"
  ],
  "properties": {
    "prediction_id": {
      "type": "string"
    },
    "prediction_contract_ref": {
      "$ref": "common.schema.json#/$defs/reference"
    },
    "target": {
      "type": "string"
    },
    "unit": {
      "type": "string"
    },
    "horizon": {
      "type": "string"
    },
    "information_cutoff": {
      "type": "string",
      "format": "date-time"
    },
    "population": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "model_version": {
      "$ref": "common.schema.json#/$defs/reference"
    },
    "prediction": {
      "$ref": "common.schema.json#/$defs/typed_value"
    },
    "uncertainty_ref": {
      "type": "string"
    },
    "calibration_status": {
      "enum": [
        "not_evaluated",
        "uncalibrated",
        "calibrated"
      ]
    },
    "transport_scope": {
      "type": "string"
    },
    "failure_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "observed_outcome_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "provenance": {
      "$ref": "common.schema.json#/$defs/provenance"
    }
  }
}
