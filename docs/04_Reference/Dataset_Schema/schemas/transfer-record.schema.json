{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "transfer-record.schema.json",
  "title": "Computational Interaction Transfer Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["transfer_id", "transfer_contract_ref", "source_episode_ref", "target_episode_ref", "experience_state_ref", "baseline_ref", "counterfactual_ref", "outcome", "classification", "uncertainty_ref", "transport_limits", "provenance"],
  "properties": {
    "transfer_id": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "transfer_contract_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "source_episode_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "target_episode_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "experience_state_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "baseline_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "counterfactual_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "outcome": { "$ref": "common.schema.json#/$defs/typed_value" },
    "classification": { "enum": ["positive", "null", "negative", "incomparable"] },
    "uncertainty_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "transport_limits": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/non_empty_string" } },
    "provenance": { "$ref": "common.schema.json#/$defs/provenance" }
  }
}
