{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy-hypothesis.schema.json",
  "title": "Computational Interaction Strategy Hypothesis",
  "type": "object",
  "additionalProperties": false,
  "required": ["hypothesis_id", "strategy_contract_ref", "participant_ref", "episode_refs", "state_abstraction_ref", "rival_refs", "diagnostic_contingencies", "evidence_refs", "uncertainty_ref", "status", "prohibited_inferences", "provenance"],
  "properties": {
    "hypothesis_id": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "strategy_contract_ref": { "$ref": "common.schema.json#/$defs/reference" },
    "participant_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "episode_refs": { "type": "array", "minItems": 2, "items": { "$ref": "common.schema.json#/$defs/non_empty_string" }, "uniqueItems": true },
    "state_abstraction_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "rival_refs": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/non_empty_string" }, "uniqueItems": true },
    "diagnostic_contingencies": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/non_empty_string" } },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/non_empty_string" }, "uniqueItems": true },
    "uncertainty_ref": { "$ref": "common.schema.json#/$defs/non_empty_string" },
    "status": { "enum": ["proposed", "supported", "not_supported", "inconclusive"] },
    "prohibited_inferences": { "type": "array", "minItems": 1, "items": { "$ref": "common.schema.json#/$defs/non_empty_string" } },
    "provenance": { "$ref": "common.schema.json#/$defs/provenance" }
  }
}
