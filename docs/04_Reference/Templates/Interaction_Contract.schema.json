{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Interaction_Contract.schema.json",
  "title": "Computational Interaction Interaction Contract",
  "allOf": [
    {
      "$ref": "Contract_Common.schema.json"
    },
    {
      "type": "object",
      "required": [
        "participant_refs",
        "environment_refs",
        "boundary",
        "timescale",
        "initiation_conditions",
        "initial_state_ref",
        "coupling_relations",
        "perturbation_conditions",
        "uptake_conditions",
        "preconditions",
        "postconditions",
        "event_types",
        "transition_semantics_ref",
        "protocol",
        "invariants",
        "evidence_requirements",
        "failure_conditions",
        "recovery_conditions",
        "completion_conditions",
        "episode_identity_rule",
        "provenance_requirements",
        "uncertainty_assumptions"
      ],
      "properties": {
        "participant_refs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "environment_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "boundary": {
          "type": "string",
          "minLength": 1
        },
        "timescale": {
          "type": "string",
          "minLength": 1
        },
        "initiation_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "initial_state_ref": {
          "type": "string",
          "minLength": 1
        },
        "coupling_relations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_ref",
              "target_ref",
              "pathway",
              "possible_consequence"
            ],
            "properties": {
              "source_ref": {
                "type": "string",
                "minLength": 1
              },
              "target_ref": {
                "type": "string",
                "minLength": 1
              },
              "pathway": {
                "type": "string",
                "minLength": 1
              },
              "possible_consequence": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "perturbation_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "uptake_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "postconditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "event_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "transition_semantics_ref": {
          "$ref": "../Dataset_Schema/schemas/common.schema.json#/$defs/reference"
        },
        "protocol": {
          "type": "string",
          "minLength": 1
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "evidence_requirements": {
          "type": "object",
          "minProperties": 1
        },
        "failure_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "recovery_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "completion_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "episode_identity_rule": {
          "type": "string",
          "minLength": 1
        },
        "provenance_requirements": {
          "type": "object",
          "minProperties": 1
        },
        "uncertainty_assumptions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
