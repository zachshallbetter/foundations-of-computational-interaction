{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Measurement_Contract.schema.json",
  "title": "CompInt Measurement Contract",
  "allOf": [
    {
      "$ref": "Contract_Common.schema.json"
    },
    {
      "type": "object",
      "required": [
        "measurand",
        "unit",
        "level_of_analysis",
        "observation_model",
        "instrument_ref",
        "operationalization",
        "coding_rules",
        "estimator",
        "scale_type",
        "permissible_transformations",
        "permissible_comparisons",
        "permitted_interpretations",
        "uncertainty_model_ref",
        "uncertainty_budget",
        "reliability_evidence_requirements",
        "validity_evidence_requirements",
        "comparison_scope",
        "missingness_rules"
      ],
      "properties": {
        "measurand": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "level_of_analysis": {
          "type": "string",
          "minLength": 1
        },
        "observation_model": {
          "type": "string",
          "minLength": 1
        },
        "instrument_ref": {
          "$ref": "../Dataset_Schema/schemas/common.schema.json#/$defs/reference"
        },
        "operationalization": {
          "type": "string",
          "minLength": 1
        },
        "coding_rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "estimator": {
          "type": "string",
          "minLength": 1
        },
        "scale_type": {
          "enum": [
            "nominal",
            "ordinal",
            "interval",
            "ratio",
            "count",
            "binary",
            "duration"
          ]
        },
        "permissible_transformations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "permissible_comparisons": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "permitted_interpretations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "uncertainty_model_ref": {
          "$ref": "../Dataset_Schema/schemas/common.schema.json#/$defs/reference"
        },
        "uncertainty_budget": {
          "type": "object",
          "minProperties": 1
        },
        "reliability_evidence_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "validity_evidence_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "comparison_scope": {
          "$ref": "../Dataset_Schema/schemas/common.schema.json#/$defs/scope"
        },
        "missingness_rules": {
          "type": "object",
          "minProperties": 1
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
