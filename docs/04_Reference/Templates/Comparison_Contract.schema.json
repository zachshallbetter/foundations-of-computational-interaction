{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Comparison_Contract.schema.json",
  "title": "CompInt Comparison Contract",
  "allOf": [
    {
      "$ref": "Contract_Common.schema.json"
    },
    {
      "type": "object",
      "required": [
        "left_ref",
        "right_ref",
        "comparison_purpose",
        "reference_frame",
        "correspondence_mapping",
        "invariants",
        "admissible_transformations",
        "gates",
        "profile_dimensions",
        "measure_refs",
        "thresholds",
        "uncertainty_model_ref",
        "evidence_requirements",
        "validity_domain",
        "result_types",
        "ethics_accessibility_vetoes"
      ],
      "properties": {
        "left_ref": {
          "type": "string",
          "minLength": 1
        },
        "right_ref": {
          "type": "string",
          "minLength": 1
        },
        "comparison_purpose": {
          "type": "string",
          "minLength": 1
        },
        "reference_frame": {
          "type": "string",
          "minLength": 1
        },
        "correspondence_mapping": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object", "minProperties": 1 }
        },
        "invariants": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "admissible_transformations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "gates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target",
            "boundary",
            "opportunity",
            "observation",
            "measurement",
            "correspondence",
            "ethics_accessibility"
          ],
          "properties": {
            "target": {
              "type": "object",
              "required": [
                "criterion",
                "failure_result"
              ],
              "properties": {
                "criterion": {
                  "type": "string",
                  "minLength": 1
                },
                "failure_result": {
                  "const": "incomparable"
                }
              },
              "additionalProperties": false
            },
            "boundary": {
              "type": "object",
              "required": [
                "criterion",
                "failure_result"
              ],
              "properties": {
                "criterion": {
                  "type": "string",
                  "minLength": 1
                },
                "failure_result": {
                  "const": "incomparable"
                }
              },
              "additionalProperties": false
            },
            "opportunity": {
              "type": "object",
              "required": [
                "criterion",
                "failure_result"
              ],
              "properties": {
                "criterion": {
                  "type": "string",
                  "minLength": 1
                },
                "failure_result": {
                  "const": "incomparable"
                }
              },
              "additionalProperties": false
            },
            "observation": {
              "type": "object",
              "required": [
                "criterion",
                "failure_result"
              ],
              "properties": {
                "criterion": {
                  "type": "string",
                  "minLength": 1
                },
                "failure_result": {
                  "const": "incomparable"
                }
              },
              "additionalProperties": false
            },
            "measurement": {
              "type": "object",
              "required": [
                "criterion",
                "failure_result"
              ],
              "properties": {
                "criterion": {
                  "type": "string",
                  "minLength": 1
                },
                "failure_result": {
                  "const": "incomparable"
                }
              },
              "additionalProperties": false
            },
            "correspondence": {
              "type": "object",
              "required": [
                "criterion",
                "failure_result"
              ],
              "properties": {
                "criterion": {
                  "type": "string",
                  "minLength": 1
                },
                "failure_result": {
                  "const": "incomparable"
                }
              },
              "additionalProperties": false
            },
            "ethics_accessibility": {
              "type": "object",
              "required": [
                "criterion",
                "failure_result"
              ],
              "properties": {
                "criterion": {
                  "type": "string",
                  "minLength": 1
                },
                "failure_result": {
                  "const": "incomparable"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "profile_dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "measure_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "../Dataset_Schema/schemas/common.schema.json#/$defs/reference" }
        },
        "thresholds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object", "minProperties": 1 }
        },
        "uncertainty_model_ref": {
          "$ref": "../Dataset_Schema/schemas/common.schema.json#/$defs/reference"
        },
        "evidence_requirements": {
          "type": "object",
          "minProperties": 1
        },
        "validity_domain": {
          "type": "string",
          "minLength": 1
        },
        "result_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "token_identity",
              "typed_equivalence",
              "similarity",
              "dominance",
              "trade_off",
              "incomparable"
            ]
          },
          "uniqueItems": true
        },
        "decision_rule": {
          "type": [
            "object",
            "null"
          ]
        },
        "ethics_accessibility_vetoes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
