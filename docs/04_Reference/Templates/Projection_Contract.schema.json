{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Projection_Contract.schema.json",
  "title": "CompInt Projection Contract",
  "allOf": [
    {
      "$ref": "Contract_Common.schema.json"
    },
    {
      "type": "object",
      "required": [
        "target_ref",
        "target_host",
        "modality",
        "mapping_rule",
        "interpretation_assumptions",
        "preserved_properties",
        "transformed_properties",
        "omitted_properties",
        "introduced_properties",
        "exposed_operations",
        "signifiers",
        "feedback_channels",
        "observer_class",
        "intended_use",
        "tolerances",
        "uncertainty_refs",
        "failure_conditions"
      ],
      "properties": {
        "target_ref": {
          "$ref": "../Dataset_Schema/schemas/common.schema.json#/$defs/reference"
        },
        "target_host": {
          "type": "string",
          "minLength": 1
        },
        "modality": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "mapping_rule": {
          "type": "string",
          "minLength": 1
        },
        "interpretation_assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "preserved_properties": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "transformed_properties": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "omitted_properties": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "introduced_properties": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "exposed_operations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "signifiers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "feedback_channels": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "observer_class": {
          "type": "string",
          "minLength": 1
        },
        "intended_use": {
          "type": "string",
          "minLength": 1
        },
        "tolerances": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "uncertainty_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "failure_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
